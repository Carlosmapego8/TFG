{
  "compatibilityLevel": 1550,
  "model": {
    "name": "euro_analysis",
    "description": "Euro 2024 Analysis - Football Tournament Analytics",
    "culture": "es-ES",
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "sourceQueryCulture": "es-ES",
    "tables": [
      {
        "name": "dim_teams",
        "description": "Dimensión de equipos participantes",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    dim_teams_Table = gold_Schema{{{\"Name\"=\"dim_teams\"}}}[Data]\nin\n    dim_teams_Table"
            }
          }
        ],
        "columns": [
          { "name": "team_id", "dataType": "string" },
          { "name": "team_name", "dataType": "string" },
          { "name": "team_code", "dataType": "string" }
        ]
      },
      {
        "name": "dim_tournaments",
        "description": "Dimensión de torneos",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    dim_tournaments_Table = gold_Schema{{{\"Name\"=\"dim_tournaments\"}}}[Data]\nin\n    dim_tournaments_Table"
            }
          }
        ],
        "columns": [
          { "name": "tournament_id", "dataType": "string" },
          { "name": "tournament_name", "dataType": "string" },
          { "name": "year", "dataType": "string" }
        ]
      },
      {
        "name": "dim_groups",
        "description": "Dimensión de grupos",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    dim_groups_Table = gold_Schema{{{\"Name\"=\"dim_groups\"}}}[Data]\nin\n    dim_groups_Table"
            }
          }
        ],
        "columns": [
          { "name": "group_id", "dataType": "string" },
          { "name": "group_name", "dataType": "string" }
        ]
      },
      {
        "name": "dim_stadiums",
        "description": "Dimensión de estadios",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    dim_stadiums_Table = gold_Schema{{{\"Name\"=\"dim_stadiums\"}}}[Data]\nin\n    dim_stadiums_Table"
            }
          }
        ],
        "columns": [
          { "name": "stadium_id", "dataType": "string" },
          { "name": "stadium_name", "dataType": "string" }
        ]
      },
      {
        "name": "dim_date",
        "description": "Dimensión de fechas",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    dim_date_Table = gold_Schema{{{\"Name\"=\"dim_date\"}}}[Data]\nin\n    dim_date_Table"
            }
          }
        ],
        "columns": [
          { "name": "date_id", "dataType": "string" },
          { "name": "full_date", "dataType": "string" },
          { "name": "year", "dataType": "string" },
          { "name": "month", "dataType": "string" },
          { "name": "day", "dataType": "string" },
          { "name": "weekday", "dataType": "string" }
        ]
      },
      {
        "name": "fct_matches",
        "description": "Tabla de hechos - Partidos con métricas",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    fct_matches_Table = gold_Schema{{{\"Name\"=\"fct_matches\"}}}[Data]\nin\n    fct_matches_Table"
            }
          }
        ],
        "columns": [
          { "name": "match_id", "dataType": "string" },
          { "name": "tournament_id", "dataType": "string" },
          { "name": "group_id", "dataType": "string" },
          { "name": "stadium_id", "dataType": "string" },
          { "name": "home_team_id", "dataType": "string" },
          { "name": "away_team_id", "dataType": "string" },
          { "name": "date_id", "dataType": "string" },
          { "name": "match_number", "dataType": "string" },
          { "name": "round_number", "dataType": "string" },
          { "name": "match_hour", "dataType": "string" },
          { "name": "home_goals", "dataType": "string" },
          { "name": "away_goals", "dataType": "string" },
          { "name": "total_goals", "dataType": "string" },
          { "name": "result", "dataType": "string" }
        ],
        "measures": [
          {
            "name": "Total Partidos",
            "expression": "COUNTROWS(fct_matches)",
            "formatString": "#,0"
          },
          {
            "name": "Total Goles",
            "expression": "SUM(fct_matches[total_goals])",
            "formatString": "#,0"
          },
          {
            "name": "Media Goles/Partido",
            "expression": "AVERAGE(fct_matches[total_goals])",
            "formatString": "0.00"
          },
          {
            "name": "Victorias Local",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"home_win\")",
            "formatString": "#,0"
          },
          {
            "name": "Victorias Visitante",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"away_win\")",
            "formatString": "#,0"
          },
          {
            "name": "Empates",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"draw\")",
            "formatString": "#,0"
          },
          {
            "name": "% Victoria Local",
            "expression": "DIVIDE([Victorias Local], [Total Partidos], 0)",
            "formatString": "0.0%"
          },
          {
            "name": "% Victoria Visitante",
            "expression": "DIVIDE([Victorias Visitante], [Total Partidos], 0)",
            "formatString": "0.0%"
          },
          {
            "name": "% Empate",
            "expression": "DIVIDE([Empates], [Total Partidos], 0)",
            "formatString": "0.0%"
          }
        ]
      },
      {
        "name": "kpi_team_stats",
        "description": "Estadísticas agregadas por equipo",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    kpi_team_stats_Table = gold_Schema{{{\"Name\"=\"kpi_team_stats\"}}}[Data]\nin\n    kpi_team_stats_Table"
            }
          }
        ],
        "columns": [
          { "name": "team_id", "dataType": "string" },
          { "name": "team_name", "dataType": "string" },
          { "name": "team_code", "dataType": "string" },
          { "name": "matches_played", "dataType": "string" },
          { "name": "wins", "dataType": "string" },
          { "name": "draws", "dataType": "string" },
          { "name": "losses", "dataType": "string" },
          { "name": "goals_for", "dataType": "string" },
          { "name": "goals_against", "dataType": "string" },
          { "name": "goal_difference", "dataType": "string" },
          { "name": "points", "dataType": "string" },
          { "name": "avg_goals_per_match", "dataType": "string" }
        ]
      },
      {
        "name": "kpi_tournament_summary",
        "description": "Resumen estadístico global del torneo",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    kpi_tournament_summary_Table = gold_Schema{{{\"Name\"=\"kpi_tournament_summary\"}}}[Data]\nin\n    kpi_tournament_summary_Table"
            }
          }
        ],
        "columns": [
          { "name": "tournament_id", "dataType": "string" },
          { "name": "total_matches", "dataType": "string" },
          { "name": "total_goals", "dataType": "string" },
          { "name": "avg_goals_per_match", "dataType": "string" },
          { "name": "max_goals_in_match", "dataType": "string" },
          { "name": "total_home_wins", "dataType": "string" },
          { "name": "total_away_wins", "dataType": "string" },
          { "name": "total_draws", "dataType": "string" },
          { "name": "home_win_pct", "dataType": "string" },
          { "name": "away_win_pct", "dataType": "string" },
          { "name": "draw_pct", "dataType": "string" }
        ]
      },
      {
        "name": "kpi_stadium_stats",
        "description": "Estadísticas por estadio",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    kpi_stadium_stats_Table = gold_Schema{{{\"Name\"=\"kpi_stadium_stats\"}}}[Data]\nin\n    kpi_stadium_stats_Table"
            }
          }
        ],
        "columns": [
          { "name": "stadium_id", "dataType": "string" },
          { "name": "stadium_name", "dataType": "string" },
          { "name": "matches_hosted", "dataType": "string" },
          { "name": "total_goals", "dataType": "string" },
          { "name": "avg_goals_per_match", "dataType": "string" },
          { "name": "home_wins", "dataType": "string" },
          { "name": "away_wins", "dataType": "string" },
          { "name": "draws", "dataType": "string" }
        ]
      },
      {
        "name": "kpi_group_standings",
        "description": "Clasificación de la fase de grupos",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    kpi_group_standings_Table = gold_Schema{{{\"Name\"=\"kpi_group_standings\"}}}[Data]\nin\n    kpi_group_standings_Table"
            }
          }
        ],
        "columns": [
          { "name": "group_name", "dataType": "string" },
          { "name": "team_name", "dataType": "string" },
          { "name": "team_code", "dataType": "string" },
          { "name": "matches_played", "dataType": "string" },
          { "name": "wins", "dataType": "string" },
          { "name": "draws", "dataType": "string" },
          { "name": "losses", "dataType": "string" },
          { "name": "goals_for", "dataType": "string" },
          { "name": "goals_against", "dataType": "string" },
          { "name": "goal_difference", "dataType": "string" },
          { "name": "points", "dataType": "string" }
        ]
      }
    ],
    "relationships": [
      {
        "name": "rel_fct_tournament",
        "fromTable": "fct_matches",
        "fromColumn": "tournament_id",
        "toTable": "dim_tournaments",
        "toColumn": "tournament_id",
        "isActive": true
      },
      {
        "name": "rel_fct_group",
        "fromTable": "fct_matches",
        "fromColumn": "group_id",
        "toTable": "dim_groups",
        "toColumn": "group_id",
        "isActive": true
      },
      {
        "name": "rel_fct_stadium",
        "fromTable": "fct_matches",
        "fromColumn": "stadium_id",
        "toTable": "dim_stadiums",
        "toColumn": "stadium_id",
        "isActive": true
      },
      {
        "name": "rel_fct_home_team",
        "fromTable": "fct_matches",
        "fromColumn": "home_team_id",
        "toTable": "dim_teams",
        "toColumn": "team_id",
        "isActive": true,
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "rel_fct_away_team",
        "fromTable": "fct_matches",
        "fromColumn": "away_team_id",
        "toTable": "dim_teams",
        "toColumn": "team_id",
        "isActive": false,
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "rel_fct_date",
        "fromTable": "fct_matches",
        "fromColumn": "date_id",
        "toTable": "dim_date",
        "toColumn": "date_id",
        "isActive": true
      }
    ]
  }
}
