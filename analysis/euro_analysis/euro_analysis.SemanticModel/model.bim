      {
        "name": "fct_matches",
        "description": "Tabla de hechos - Partidos con métricas",
        "lineageTag": "lineage-fct_matches",
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Odbc.Database(\"Driver={PostgreSQL Unicode};Server=localhost;Port=5432;Database=tfg_warehouse;UID=postgres;PWD=password;\"),\n    gold_Schema = Source{{\"Schema\"=\"gold\"}}[Data],\n    fct_matches_Table = gold_Schema{{{\"Name\"=\"fct_matches\"}}}[Data]\nin\n    fct_matches_Table"
            }
          }
        ],
        "columns": [
          {
            "name": "match_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-match_id"
          },
          {
            "name": "tournament_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-tournament_id"
          },
          {
            "name": "group_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-group_id"
          },
          {
            "name": "stadium_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-stadium_id"
          },
          {
            "name": "home_team_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-home_team_id"
          },
          {
            "name": "away_team_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-away_team_id"
          },
          {
            "name": "date_id",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-date_id"
          },
          {
            "name": "match_number",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-match_number"
          },
          {
            "name": "round_number",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-round_number"
          },
          {
            "name": "match_hour",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-match_hour"
          },
          {
            "name": "home_goals",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-home_goals"
          },
          {
            "name": "away_goals",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-away_goals"
          },
          {
            "name": "total_goals",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-total_goals"
          },
          {
            "name": "result",
            "dataType": "string",
            "lineageTag": "lineage-fct_matches-result"
          }
        ],
        "measures": [
          {
            "name": "Total Partidos",
            "expression": "COUNTROWS(fct_matches)",
            "formatString": "#,0",
            "lineageTag": "measure-total-matches"
          },
          {
            "name": "Total Goles",
            "expression": "SUM(fct_matches[total_goals])",
            "formatString": "#,0",
            "lineageTag": "measure-total-goals"
          },
          {
            "name": "Media Goles/Partido",
            "expression": "AVERAGE(fct_matches[total_goals])",
            "formatString": "0.00",
            "lineageTag": "measure-avg-goals"
          },
          {
            "name": "Victorias Local",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"home_win\")",
            "formatString": "#,0",
            "lineageTag": "measure-home-wins"
          },
          {
            "name": "Victorias Visitante",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"away_win\")",
            "formatString": "#,0",
            "lineageTag": "measure-away-wins"
          },
          {
            "name": "Empates",
            "expression": "CALCULATE(COUNTROWS(fct_matches), fct_matches[result]=\"draw\")",
            "formatString": "#,0",
            "lineageTag": "measure-draws"
          },
          {
            "name": "% Victoria Local",
            "expression": "DIVIDE([Victorias Local], [Total Partidos], 0)",
            "formatString": "0.0%",
            "lineageTag": "measure-home-win-pct"
          },
          {
            "name": "% Victoria Visitante",
            "expression": "DIVIDE([Victorias Visitante], [Total Partidos], 0)",
            "formatString": "0.0%",
            "lineageTag": "measure-away-win-pct"
          },
          {
            "name": "% Empate",
            "expression": "DIVIDE([Empates], [Total Partidos], 0)",
            "formatString": "0.0%",
            "lineageTag": "measure-draw-pct"
          }
        ]
      },
